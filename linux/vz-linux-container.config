# Container sandbox kernel config fragment for vz Linux guests on Apple
# Virtualization.framework.
#
# This profile intentionally starts from allnoconfig. Keep this file as the
# positive contract for deployed container/sandbox VMs: virtio/vsock plumbing,
# OCI runtime basics, btrfs snapshot support, and common TCP networking.

# Build shape
CONFIG_EXPERT=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_LOCALVERSION="-vz-container"
CONFIG_LOCALVERSION_AUTO=n
CONFIG_MODULES=n

# Boot initramfs and Rust/BusyBox userspace
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
# CONFIG_ELF_CORE is not set
# CONFIG_COREDUMP is not set

# Apple Virtualization.framework guest plumbing
CONFIG_OF=y
CONFIG_OF_FLATTREE=y
CONFIG_OF_EARLY_FLATTREE=y
CONFIG_OF_ADDRESS=y
CONFIG_OF_IRQ=y
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_FS=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# Host<->guest control channel and console
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_TTY=y
CONFIG_UNIX98_PTYS=y
CONFIG_HVC_DRIVER=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# Runtime filesystems and container mounts
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
# CONFIG_EXT4_FS_SECURITY is not set
CONFIG_FS_POSIX_ACL=y

# Explicitly retained for future container snapshot/rollback support
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
# CONFIG_BTRFS_DEBUG is not set
# CONFIG_BTRFS_ASSERT is not set
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_LOOP_MIN_COUNT=8
CONFIG_MSDOS_PARTITION=y
CONFIG_EFI_PARTITION=y

# Networking for guest agent, service stacks, and NAT
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETDEVICES=y
CONFIG_NET_NS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y
# CONFIG_BRIDGE_NETFILTER is not set
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_NAT=y
CONFIG_NFT_CT=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_COMPAT=y

# OCI/runtime basics. PID/IPC/UTS/user/time namespaces stay off because the
# current guest bundle strips them before invoking youki.
CONFIG_NAMESPACES=y
CONFIG_CGROUPS=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
# CONFIG_PID_NS is not set
# CONFIG_IPC_NS is not set
# CONFIG_UTS_NS is not set
# CONFIG_USER_NS is not set
# CONFIG_TIME_NS is not set
# CONFIG_POSIX_MQUEUE is not set
# CONFIG_SYSVIPC is not set

# Do not expose build/config internals or broad introspection surfaces.
# CONFIG_IKCONFIG is not set
# CONFIG_KALLSYMS is not set
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_DEBUG_INFO is not set
# CONFIG_FTRACE is not set
# CONFIG_TRACING is not set
# CONFIG_PROFILING is not set
# CONFIG_PERF_EVENTS is not set
# CONFIG_AUDIT is not set
# CONFIG_BPF_SYSCALL is not set
# CONFIG_CGROUP_BPF is not set
CONFIG_IO_URING=y
# CONFIG_AIO is not set

# Developer-only / unused hardware surfaces.
# CONFIG_VIRTUALIZATION is not set
# CONFIG_KVM is not set
# CONFIG_TUN is not set
# CONFIG_USB is not set
# CONFIG_USB_SUPPORT is not set
# CONFIG_USB_GADGET is not set
# CONFIG_DRM is not set
# CONFIG_SOUND is not set
# CONFIG_INPUT is not set
# CONFIG_BT is not set
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_NFS_FS is not set
# CONFIG_CIFS is not set
# CONFIG_9P_FS is not set
# CONFIG_SQUASHFS is not set
# CONFIG_FAT_FS is not set
# CONFIG_VFAT_FS is not set
# CONFIG_EFIVAR_FS is not set
# CONFIG_SCSI is not set
# CONFIG_ATA is not set
# CONFIG_NVME_CORE is not set
# CONFIG_PCI_ENDPOINT is not set

# Avoid known bad/expensive VM memory features under Virtualization.framework.
# CONFIG_MEMCG is not set
# CONFIG_ZONE_DMA is not set
# CONFIG_ZONE_DMA32 is not set
# CONFIG_TRANSPARENT_HUGEPAGE is not set
# CONFIG_NUMA is not set
# CONFIG_SWAP is not set
# CONFIG_CMA is not set
# CONFIG_HIBERNATION is not set
# CONFIG_SUSPEND is not set
# CONFIG_KEXEC is not set
# CONFIG_CRASH_DUMP is not set
