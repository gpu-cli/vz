# Minimal kernel config fragment for vz Linux guests on Apple Virtualization.framework.

# Core guest plumbing
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_FS=y
CONFIG_FUSE_FS=y

# Vsock host<->guest channel
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# Filesystems and runtime mounts
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_EXT4_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# Networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# Container networking (veth pairs + bridge for per-service netns isolation)
CONFIG_NET_NS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y

# Cgroups / namespaces
CONFIG_NAMESPACES=y
CONFIG_CGROUPS=y

# Console support over virtio
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_HVC_DRIVER=y
CONFIG_HVC_VIRTIO=y

# Keep kernel simple and monolithic
CONFIG_MODULES=n
CONFIG_SOUND=n
CONFIG_USB=n
CONFIG_DRM=n
CONFIG_INPUT=n
CONFIG_SELINUX=n
CONFIG_SECURITY=n
CONFIG_DEBUG_KERNEL=n
CONFIG_FTRACE=n
CONFIG_BT=n
CONFIG_WIRELESS=n
CONFIG_WLAN=n
CONFIG_NFS_FS=n
CONFIG_CIFS=n
