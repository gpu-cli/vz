# Minimal kernel config fragment for vz Linux guests on Apple Virtualization.framework.

# Allow this fragment to opt out of broad default-on developer features.
CONFIG_EXPERT=y

# Core guest plumbing
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_FS=y
CONFIG_FUSE_FS=y

# Vsock host<->guest channel
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# Filesystems and runtime mounts
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# Networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# Container networking (veth pairs + bridge for per-service netns isolation)
CONFIG_NET_NS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y

# TUN/TAP (Firecracker uses tap devices for guest networking)
CONFIG_TUN=y

# Netfilter / iptables (required for NAT masquerade in proxy VMs)
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y

# nftables (modern netfilter replacement — tables, chains, NAT/masquerade,
# conntrack, match expressions, and compat layer for iptables-nft)
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CHAIN_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_NAT=y
CONFIG_NFT_CT=y
CONFIG_NFT_META=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_LOG=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_COMPAT=y

# Cgroups / namespaces
CONFIG_NAMESPACES=y
CONFIG_CGROUPS=y

# Console support over virtio
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_HVC_DRIVER=y
CONFIG_HVC_VIRTIO=y

# KVM (nested virtualization — run Firecracker/Cloud Hypervisor inside the guest)
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=y

# Disable sorttable (requires elf.h, unavailable on macOS host builds)
CONFIG_BUILDTIME_TABLE_SORT=n

# Keep kernel simple and monolithic
CONFIG_MODULES=n
CONFIG_SOUND=n
CONFIG_USB=n
CONFIG_DRM=n
CONFIG_INPUT=n
CONFIG_SELINUX=n
CONFIG_SECURITY=n
CONFIG_DEBUG_KERNEL=n
CONFIG_KALLSYMS=n
CONFIG_FTRACE=n
CONFIG_IKCONFIG=n
CONFIG_IKCONFIG_PROC=n
CONFIG_AUDIT=n
CONFIG_PROFILING=n
CONFIG_PERF_EVENTS=n
CONFIG_BPF_SYSCALL=n
CONFIG_CGROUP_BPF=n
CONFIG_IO_URING=y
CONFIG_AIO=n
CONFIG_CORESIGHT=n
CONFIG_ARM_PMU=n
CONFIG_BT=n
CONFIG_WIRELESS=n
CONFIG_WLAN=n
CONFIG_NFS_FS=n
CONFIG_CIFS=n
CONFIG_9P_FS=n
CONFIG_SQUASHFS=n
CONFIG_FAT_FS=n
CONFIG_VFAT_FS=n
CONFIG_USB_GADGET=n
CONFIG_SCSI=n
CONFIG_ATA=n
CONFIG_VT=n

# Disable memory cgroups (causes false OOM in minimal VMs)
CONFIG_MEMCG=n

# Disable features that cause memory allocation issues under Virtualization.framework
# PHYS_OFFSET is very high → DMA/DMA32 zones are empty → zone allocation failures
CONFIG_ZONE_DMA=n
CONFIG_ZONE_DMA32=n
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_NUMA=n
CONFIG_SWAP=n
CONFIG_CMA=n

# Virtio memory balloon — guest-side responder for the host's runtime
# set_target_memory_size() requests. Without this driver, Apple's framework
# can attach the balloon device but the guest never inflates it, so pages
# the guest has touched stay resident on the host indefinitely. Required
# for the multi-VM consumer story (vz-srr/vz-68z/vz-59c) to support memory
# reclaim under load.
CONFIG_VIRTIO_BALLOON=y
