#!/bin/busybox sh

set -eu

echo "[vz-init] booting initramfs"

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev || true
mount -t tmpfs tmpfs /tmp

mkdir -p /run /mnt/rootfs /mnt/merged

# Create device nodes that devtmpfs may not auto-populate.
# /dev/kvm: needed for nested virtualization (Firecracker, QEMU).
# /dev/net/tun: needed for tap networking (Firecracker guest NICs).
if [ -e /sys/devices/virtual/misc/kvm ] && [ ! -e /dev/kvm ]; then
  /bin/busybox mknod /dev/kvm c 10 232 2>/dev/null || true
fi
if [ -e /sys/class/misc/tun ] && [ ! -e /dev/net/tun ]; then
  mkdir -p /dev/net
  /bin/busybox mknod /dev/net/tun c 10 200 2>/dev/null || true
fi

# Optional runtime binary share (host-provided youki artifact).
mkdir -p /mnt/oci-runtime-bin

install_youki_binary() {
  target_path="$1"
  if [ ! -f /mnt/oci-runtime-bin/youki ]; then
    return 0
  fi

  target_dir="${target_path%/*}"
  mkdir -p "$target_dir" || return 1
  cp /mnt/oci-runtime-bin/youki "$target_path" || return 1
  /bin/busybox chmod +x "$target_path" || return 1
  return 0
}

# Ensure loopback works for localhost services and port forwarding.
/bin/ip link set dev lo up >/dev/console 2>&1 || true


# Optional DHCP setup if a virtio-net device is present.
# Run in background so missing network does not block guest-agent startup.
if [ -d /sys/class/net/eth0 ] && [ -x /sbin/udhcpc ]; then
  /bin/ip link set dev eth0 up >/dev/console 2>&1 || true
  /sbin/udhcpc -i eth0 -s /etc/udhcpc.script -q -b -t 5 -T 1 >/dev/console 2>&1 &
fi

switch_root_into_overlay_rootfs() {
  echo "[vz-init] preparing overlay rootfs"

  mkdir -p /run/vz-oci/overlay || return 1
  mount -t tmpfs tmpfs /run/vz-oci || return 1
  mkdir -p /run/vz-oci/overlay/upper /run/vz-oci/overlay/work || return 1
  mount -t overlay overlay \
    -o lowerdir=/mnt/rootfs,upperdir=/run/vz-oci/overlay/upper,workdir=/run/vz-oci/overlay/work \
    /mnt/merged || return 1

  ROOTFS=/mnt/merged

  mkdir -p "$ROOTFS/proc" "$ROOTFS/sys" "$ROOTFS/dev" "$ROOTFS/tmp" "$ROOTFS/run" || return 1
  mkdir -p "$ROOTFS/usr/local/bin" "$ROOTFS/etc" || return 1

  mount -t proc proc "$ROOTFS/proc" || return 1
  mount -t sysfs sysfs "$ROOTFS/sys" || return 1
  mount -t devtmpfs devtmpfs "$ROOTFS/dev" || true
  mount -t tmpfs tmpfs "$ROOTFS/tmp" || return 1

  # Create device nodes that devtmpfs may not auto-populate in the chroot.
  if [ -e /sys/devices/virtual/misc/kvm ] && [ ! -e "$ROOTFS/dev/kvm" ]; then
    /bin/busybox mknod "$ROOTFS/dev/kvm" c 10 232 2>/dev/null || true
  fi
  if [ -e /sys/class/misc/tun ] && [ ! -e "$ROOTFS/dev/net/tun" ]; then
    mkdir -p "$ROOTFS/dev/net"
    /bin/busybox mknod "$ROOTFS/dev/net/tun" c 10 200 2>/dev/null || true
  fi

  # Mount cgroup2 for OCI container runtime (youki) support.
  mkdir -p "$ROOTFS/sys/fs/cgroup"
  mount -t cgroup2 none "$ROOTFS/sys/fs/cgroup" || true

  cp /usr/bin/vz-guest-agent "$ROOTFS/usr/local/bin/vz-guest-agent" || return 1
  /bin/busybox chmod +x "$ROOTFS/usr/local/bin/vz-guest-agent" || return 1

  if [ ! -f "$ROOTFS/etc/resolv.conf" ]; then
    cp /etc/resolv.conf "$ROOTFS/etc/resolv.conf" || return 1
  fi
  cp /etc/udhcpc.script "$ROOTFS/etc/udhcpc.script" || return 1
  /bin/busybox chmod +x "$ROOTFS/etc/udhcpc.script" || return 1

  install_youki_binary "$ROOTFS/usr/local/bin/youki" || return 1
  install_youki_binary "$ROOTFS/run/vz-oci/bin/youki" || return 1

  # Copy busybox into rootfs for network setup commands.
  mkdir -p "$ROOTFS/bin" "$ROOTFS/sbin"
  cp /bin/busybox "$ROOTFS/bin/busybox" || return 1
  # Install applet symlinks using busybox's built-in mechanism.
  # Manual `ln -sf` fails on some overlayfs configurations.
  chroot "$ROOTFS" /bin/busybox --install -s /bin 2>/dev/null || \
    /bin/busybox --install -s "$ROOTFS/bin" 2>/dev/null || true

  # Bind-mount VirtioFS rootfs share directly into chroot so container
  # rootfs directories written after overlay mount are visible.
  # Overlay caches lowerdir entries, so new files added via VirtioFS
  # won't appear through the overlay — but a direct bind mount works.
  mkdir -p "$ROOTFS/vz-rootfs"
  mount --bind /mnt/rootfs "$ROOTFS/vz-rootfs" || return 1

  # Bind-mount VirtioFS volume shares (vz-mount-*) into the chroot.
  # Container OCI bundles reference /mnt/vz-mount-N as bind mount sources.
  # Without these bind mounts, youki can't find the VirtioFS shares
  # from inside the chroot.
  vidx=0
  while true; do
    vtag="vz-mount-$vidx"
    vsrc="/mnt/$vtag"
    vdst="$ROOTFS/mnt/$vtag"
    if [ -d "$vsrc" ]; then
      mkdir -p "$vdst"
      mount --bind "$vsrc" "$vdst" || \
        echo "[vz-init] warning: failed to bind-mount $vsrc to $vdst"
      echo "[vz-init] chroot bind-mount $vsrc -> /mnt/$vtag"
      vidx=$((vidx + 1))
    else
      break
    fi
  done

  # Bind-mount user volume shares into the chroot at their target paths.
  # Target paths are encoded in kernel cmdline as vz.mount.N=/target/path.
  for param in $(cat /proc/cmdline); do
    case "$param" in
      vz.mount.*=*)
        idx="${param#vz.mount.}"
        idx="${idx%%=*}"
        target="${param#*=}"
        src="/mnt/vz-mount-$idx"
        if [ -d "$src" ]; then
          mkdir -p "$ROOTFS$target"
          mount --bind "$src" "$ROOTFS$target" || \
            echo "[vz-init] warning: failed to bind-mount $src to $ROOTFS$target"
          echo "[vz-init] volume $src -> $target"
        fi
        ;;
    esac
  done

  echo "[vz-init] entering rootfs via chroot and starting guest agent on vsock 7424"

  # Run guest agent as a child process (not PID 1) to avoid OOM killer deadlock.
  # PID 1 is unkillable; if the agent triggers OOM as PID 1, the kernel panics.
  chroot "$ROOTFS" /usr/local/bin/vz-guest-agent --port 7424 --bind-timeout-secs 30 &
  wait

  return 1
}

ROOTFS_READY=0

# Optional VirtioFS rootfs mount (used by container runtime path).
if mount -t virtiofs rootfs /mnt/rootfs 2>/dev/null; then
  echo "[vz-init] mounted virtiofs rootfs at /mnt/rootfs"
  # Note: we do NOT remount /mnt/rootfs read-only here. Overlay works fine
  # with an rw lowerdir (writes go to upperdir, lowerdir is never modified
  # through the overlay). Keeping /mnt/rootfs rw allows the bind mount at
  # /vz-rootfs to also be rw, which the OCI runtime needs for container setup.
  ROOTFS_READY=1
else
  echo "[vz-init] no rootfs virtiofs mount available, continuing"
fi

if mount -t virtiofs oci-runtime-bin /mnt/oci-runtime-bin 2>/dev/null; then
  echo "[vz-init] mounted virtiofs oci-runtime-bin at /mnt/oci-runtime-bin"
else
  echo "[vz-init] no oci-runtime-bin virtiofs mount available"
fi

# Mount user-provided VirtioFS volume shares (vz-mount-0, vz-mount-1, ...).
# These are configured when --volume is passed to `vz oci run`.
idx=0
while true; do
  tag="vz-mount-$idx"
  mount_point="/mnt/$tag"
  mkdir -p "$mount_point"
  if mount -t virtiofs "$tag" "$mount_point" 2>/dev/null; then
    echo "[vz-init] mounted virtiofs $tag at $mount_point"
  else
    # No more mount shares — stop probing.
    rmdir "$mount_point" 2>/dev/null || true
    break
  fi
  idx=$((idx + 1))
done

if ! install_youki_binary /usr/local/bin/youki; then
  echo "[vz-init] failed to stage youki in initramfs userland"
fi

if [ "$ROOTFS_READY" -eq 1 ]; then
  if ! switch_root_into_overlay_rootfs; then
    echo "[vz-init] rootfs setup failed, falling back to initramfs userland"
  fi
fi

echo "[vz-init] starting guest agent on vsock 7424"
/usr/bin/vz-guest-agent --port 7424 &
wait
